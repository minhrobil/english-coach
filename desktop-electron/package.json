{
  "name": "english-coach-desktop-electron",
  "version": "0.1.0",
  "private": true,
  "description": "English Coach desktop app (Electron, Windows-first, macOS-ready)",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "set ELECTRON_RUN_AS_NODE=&& wait-on tcp:5173 && tsc -p tsconfig.node.json && copy /Y electron\\preload.cjs dist-electron\\electron\\preload.cjs >nul && electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json && copy /Y electron\\preload.cjs dist-electron\\electron\\preload.cjs >nul",
    "start": "set ELECTRON_RUN_AS_NODE=&& electron ."
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
